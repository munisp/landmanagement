# IDLR-PTS Platform environment template
# Copy to .env and adjust for your deployment environment.

# --------------------------------------------------
# Core application
# --------------------------------------------------
NODE_ENV=production
APP_NAME=IDLR-PTS Platform
APP_VERSION=1.0.0
PORT=3000
FRONTEND_URL=http://localhost:3000
VITE_APP_URL=http://localhost:3000
VITE_APP_ID=idlr-pts-platform
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --------------------------------------------------
# HTTP security hardening
# --------------------------------------------------
# Max request body size accepted by Express (default: 50mb, for scanned documents)
MAX_REQUEST_SIZE=50mb
# Set to "true" ONLY if the UI is served cross-origin and session cookies must
# be sent cross-site (SameSite=None). Default is the safer SameSite=Lax.
CROSS_SITE_COOKIES=false
# Set to "true" on Manus-hosted production deployments, whose index.html
# injects an inline manus-runtime script; otherwise production CSP is
# script-src 'self' (strict).
CSP_ALLOW_INLINE_SCRIPTS=false

# --------------------------------------------------
# Database and cache
# --------------------------------------------------
DATABASE_URL=postgresql://idlr_user:idlr_password@localhost:5432/idlr_pts
POSTGRES_URL=postgresql://idlr_user:idlr_password@localhost:5432/idlr_pts
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=30000
DB_QUERY_TIMEOUT=15000
DB_STATEMENT_TIMEOUT=15000
DB_SSL=false
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000

# --------------------------------------------------
# Authentication and security
# --------------------------------------------------
JWT_SECRET=change-me-in-production-jwt-secret
ENCRYPTION_KEY=change-me-in-production-32-char-key
VALID_API_KEYS=local-dev-key-1,local-dev-key-2
OWNER_OPEN_ID=system-owner
OAUTH_SERVER_URL=http://localhost:8080
KEYCLOAK_URL=http://localhost:8089
KEYCLOAK_REALM=idlr
KEYCLOAK_CLIENT_ID=idlr-pts-platform
KEYCLOAK_CLIENT_SECRET=keycloak-placeholder-secret
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
PERMIFY_URL=http://localhost:3476
OPENAPPSEC_URL=http://localhost:8099
SENTRY_DSN=

# --------------------------------------------------
# Email and notifications
# --------------------------------------------------
FROM_EMAIL=no-reply@idlr.local
FROM_NAME=IDLR PTS Platform
SENDGRID_API_KEY=sendgrid-placeholder-key
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/placeholder
SLACK_ALERT_CHANNEL=#platform-alerts
ALERTS_ENABLED=true
ALERT_CHANNELS=email,slack
ALERT_EMAIL_RECIPIENTS=ops@idlr.local,security@idlr.local
ALERT_THRESHOLD_DOWNTIME=300
ALERT_THRESHOLD_ERROR_RATE=5
ALERT_THRESHOLD_RESPONSE_TIME=2000
HEALTH_MONITOR_ENABLED=true
HEALTH_MONITOR_INTERVAL=60

# --------------------------------------------------
# AI and document services
# --------------------------------------------------
OCR_SERVICE_URL=http://localhost:8003
ODM_API_URL=http://localhost:8004
DOCUMENT_SERVICE_URL=http://localhost:8085
PARCEL_SERVICE_URL=http://localhost:8081
TITLE_SERVICE_URL=http://localhost:8082
TRANSACTION_SERVICE_URL=http://localhost:8083
PAYMENT_SERVICE_URL=http://localhost:8084
BLOCKCHAIN_SERVICE_URL=http://localhost:8086
LAKEHOUSE_API_URL=http://localhost:8000

# --------------------------------------------------
# Search and analytics
# --------------------------------------------------
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=elastic-password
JAEGER_ENDPOINT=http://localhost:14268/api/traces
KUBECOST_URL=http://localhost:9090
OPENCTI_URL=http://localhost:8088
OPENCTI_TOKEN=opencti-placeholder-token
WAZUH_URL=http://localhost:55000
WAZUH_USER=wazuh-user
WAZUH_PASSWORD=wazuh-password
OPA_URL=http://localhost:8181

# --------------------------------------------------
# Messaging, workflows, and service middleware
# --------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=idlr-pts-platform
KAFKA_GROUP_ID=idlr-pts-platform-group
KAFKA_SSL_ENABLED=false
KAFKA_SASL_ENABLED=false
KAFKA_SASL_MECHANISM=plain
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
FLUVIO_API_URL=http://localhost:9103
DAPR_HTTP_URL=http://localhost:3500
DAPR_GRPC_URL=http://localhost:50001
DAPR_STATE_STORE=statestore
DAPR_PUBSUB_NAME=pubsub
APISIX_ADMIN_URL=http://localhost:9180
APISIX_API_KEY=apisix-placeholder-key
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TLS_ENABLED=false
TEMPORAL_TLS_CERT=
TEMPORAL_TLS_KEY=

# --------------------------------------------------
# Hyperledger Fabric
# --------------------------------------------------
FABRIC_GATEWAY_URL=http://localhost:7051
FABRIC_CONNECTION_PROFILE=./fabric-network/connection-org1.json
FABRIC_CHANNEL_NAME=mychannel
FABRIC_CHAINCODE_NAME=idlr-chaincode
FABRIC_MSP_ID=Org1MSP
FABRIC_ORG_MSP=Org1MSP
FABRIC_USER_ID=appUser
FABRIC_WALLET_PATH=./fabric-network/wallet
FABRIC_CERT_PATH=./fabric-network/crypto-config/cert.pem
FABRIC_KEY_PATH=./fabric-network/crypto-config/key.pem

# --------------------------------------------------
# Payments and financial integrations
# --------------------------------------------------
MOJALOOP_API_URL=http://localhost:3001
MOJALOOP_API_KEY=mojaloop-placeholder-key
MOJALOOP_PARTICIPANT_ID=idlr-participant
MOJALOOP_PAYER_FSP_ID=idlr-payer-fsp
MOJALOOP_PAYEE_FSP_ID=idlr-payee-fsp
TIGERBEETLE_CLUSTER_ID=0
TIGERBEETLE_REPLICAS=localhost:3002
TIGERBEETLE_GRPC_URL=localhost:50051
BANK_API_URL=http://localhost:8090
BANK_API_KEY=bank-placeholder-key
PAYSTACK_SECRET_KEY=paystack-placeholder-key
FLUTTERWAVE_SECRET_KEY=flutterwave-placeholder-key
CREDIT_BUREAU_API_URL=http://localhost:8091
CREDIT_BUREAU_API_KEY=credit-bureau-placeholder-key
FIRS_API_URL=http://localhost:8092
FIRS_API_KEY=firs-placeholder-key
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_API_KEY=africas-talking-placeholder-key

# --------------------------------------------------
# Smart contracts and blockchain
# --------------------------------------------------
BLOCKCHAIN_RPC_URL=http://localhost:8545
BLOCKCHAIN_CHAIN_ID=31337
BLOCKCHAIN_PRIVATE_KEY=0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
POLYGON_RPC_URL=https://polygon-rpc.com
DEPLOYER_PRIVATE_KEY=0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
TEST_PRIVATE_KEY=0xabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcd
PROPERTY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000001
ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000002
MULTISIG_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000003
BUILT_IN_FORGE_API_URL=http://localhost:8545
BUILT_IN_FORGE_API_KEY=forge-placeholder-key

# --------------------------------------------------
# Optional external APIs
# --------------------------------------------------
TITLE_SERVICE_URL=http://localhost:8082
PARCEL_SERVICE_URL=http://localhost:8081
TRANSACTION_SERVICE_URL=http://localhost:8083
PAYMENT_SERVICE_URL=http://localhost:8084
DOCUMENT_SERVICE_URL=http://localhost:8085
BLOCKCHAIN_SERVICE_URL=http://localhost:8086

# IDLR-PTS Platform deployment environment contract
# Copy this file to .env and provide real values through a secret manager or
# deployment environment. Blank values are intentionally invalid where a
# service is enabled; the platform fails closed instead of using local defaults.

# -----------------------------------------------------------------------------
# Core application and HTTP policy
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
APP_NAME=IDLR-PTS Platform
APP_VERSION=1.0.0
FRONTEND_URL=
VITE_APP_URL=
VITE_APP_ID=idlr-pts-platform
ALLOWED_ORIGINS=
LOG_LEVEL=info
MAX_REQUEST_SIZE=50mb
CROSS_SITE_COOKIES=false
CSP_ALLOW_INLINE_SCRIPTS=false
ENCRYPTION_KEY=
JWT_SECRET=
OWNER_OPEN_ID=
OAUTH_SERVER_URL=

# -----------------------------------------------------------------------------
# PostgreSQL and Redis
# -----------------------------------------------------------------------------
POSTGRES_URL=
DATABASE_URL=
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=30000
DB_QUERY_TIMEOUT=15000
DB_STATEMENT_TIMEOUT=15000
REDIS_URL=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000
CACHE_ENABLED=true
RATE_LIMIT_ENABLED=true

# -----------------------------------------------------------------------------
# Keycloak identity and Permify authorization
# -----------------------------------------------------------------------------
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ADMIN_REALM=
KEYCLOAK_ADMIN_CLIENT_ID=
KEYCLOAK_ADMIN_CLIENT_SECRET=
PERMIFY_URL=
PERMIFY_TENANT_ID=

# -----------------------------------------------------------------------------
# Gateway, application security, and observability
# -----------------------------------------------------------------------------
APISIX_ADMIN_URL=
APISIX_API_KEY=
OPENAPPSEC_URL=
SENTRY_DSN=
TRACING_ENABLED=false
JAEGER_ENDPOINT=
METRICS_ENABLED=false
PROMETHEUS_PORT=
ELASTICSEARCH_URL=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
OPENCTI_URL=
OPENCTI_TOKEN=
WAZUH_URL=
WAZUH_USER=
WAZUH_PASSWORD=
OPA_URL=
KUBECOST_URL=

# -----------------------------------------------------------------------------
# Application microservices; set MICROSERVICES_ENABLED=false only when the
# database-backed monolith path is intentionally deployed without sidecars.
# -----------------------------------------------------------------------------
MICROSERVICES_ENABLED=true
MICROSERVICE_TIMEOUT_MS=3000
PARCEL_SERVICE_URL=
TITLE_SERVICE_URL=
TRANSACTION_SERVICE_URL=
PAYMENT_SERVICE_URL=
DOCUMENT_SERVICE_URL=
BLOCKCHAIN_SERVICE_URL=
IDENTITY_SERVICE_URL=
CRYPTO_AUDIT_SERVICE_URL=
GAZETTE_SERVICE_URL=

# -----------------------------------------------------------------------------
# Lakehouse, AI, document analysis, and CPU model policy
# -----------------------------------------------------------------------------
LAKEHOUSE_API_URL=
LAKEHOUSE_API_KEY=
LAKEHOUSE_ALLOWED_ORIGINS=
AI_SERVICE_URL=
OCR_SERVICE_URL=
FRAUD_SERVICE_URL=
AI_HEALTH_URL=
FRAUD_SCORE_BLOCK_THRESHOLD=
ODM_API_URL=
BUILDING_DETECTION_SERVICE_URL=
BUILDING_DETECTION_CONFIDENCE_THRESHOLD=
OCR_SERVICE_URL=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=
S3_PATH_STYLE_ACCESS=
ICEBERG_CATALOG_URI=
ICEBERG_WAREHOUSE_PATH=

# -----------------------------------------------------------------------------
# Dapr, Fluvio, Kafka compatibility, and Temporal workflows
# -----------------------------------------------------------------------------
DAPR_HTTP_URL=
DAPR_GRPC_URL=
DAPR_STATE_STORE=statestore
DAPR_PUBSUB_NAME=pubsub
FLUVIO_API_URL=
FLUVIO_CLUSTER_ENDPOINT=
FLUVIO_TOPIC_PREFIX=idlr
KAFKA_BROKERS=
KAFKA_CLIENT_ID=idlr-pts-platform
KAFKA_GROUP_ID=idlr-pts-platform-group
KAFKA_SSL_ENABLED=true
KAFKA_SASL_ENABLED=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
TEMPORAL_ADDRESS=
TEMPORAL_NAMESPACE=
TEMPORAL_PROPERTY_TRANSACTION_TASK_QUEUE=
TEMPORAL_TLS_ENABLED=true
TEMPORAL_TLS_CERT=
TEMPORAL_TLS_KEY=

# -----------------------------------------------------------------------------
# TigerBeetle native ledger and optional gRPC bridge
# -----------------------------------------------------------------------------
TIGERBEETLE_ADDRESS=
TIGERBEETLE_CLUSTER_ID=
TIGERBEETLE_REPLICAS=
TIGERBEETLE_GRPC_URL=
TIGERBEETLE_GRPC_TLS=true

# -----------------------------------------------------------------------------
# Hyperledger Fabric and smart-contract settlement
# -----------------------------------------------------------------------------
FABRIC_CONNECTION_PROFILE=
FABRIC_WALLET_PATH=
FABRIC_USER_ID=
FABRIC_ORG_MSP=
POLYGON_RPC_URL=
POLYGON_CHAIN_ID=
DEPLOYER_PRIVATE_KEY=
ESCROW_CONTRACT_ADDRESS=
PROPERTY_CONTRACT_ADDRESS=
MULTISIG_CONTRACT_ADDRESS=

# -----------------------------------------------------------------------------
# Payments, governmental systems, and external registries
# -----------------------------------------------------------------------------
MOJALOOP_API_URL=
MOJALOOP_API_KEY=
MOJALOOP_PARTICIPANT_ID=
MOJALOOP_PAYER_FSP_ID=
MOJALOOP_PAYEE_FSP_ID=
PAYSTACK_SECRET_KEY=
PAYSTACK_API_BASE_URL=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_API_BASE_URL=
BANK_API_URL=
BANK_API_KEY=
CREDIT_BUREAU_API_URL=
CREDIT_BUREAU_API_KEY=
FIRS_API_URL=
FIRS_API_KEY=

# -----------------------------------------------------------------------------
# Email, SMS, and platform alert delivery
# -----------------------------------------------------------------------------
FROM_EMAIL=
FROM_NAME=IDLR PTS Platform
SENDGRID_API_KEY=
SENDGRID_API_BASE_URL=
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=
AFRICAS_TALKING_API_BASE_URL=
SLACK_WEBHOOK_URL=
SLACK_ALERT_CHANNEL=
ALERTS_ENABLED=true
ALERT_CHANNELS=email,slack
ALERT_EMAIL_RECIPIENTS=
ALERT_THRESHOLD_DOWNTIME=300
ALERT_THRESHOLD_ERROR_RATE=5
ALERT_THRESHOLD_RESPONSE_TIME=2000
HEALTH_MONITOR_ENABLED=true
HEALTH_MONITOR_INTERVAL=60

# Durable case-concierge sessions and verified continuous AI training
CASE_CONCIERGE_SESSION_TTL_SECONDS=
FRAUD_TRAINING_START_DATE=
FRAUD_TRAINING_END_DATE=
FRAUD_TRAINING_MIN_LABELED=
MODEL_ARTIFACT_DIR=
